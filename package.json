{
  "name": "jijasbet",
  "version": "1.0.0",
  "description": "Plataforma de apuestas deportivas con pago por Yape",
  "main": "server.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
